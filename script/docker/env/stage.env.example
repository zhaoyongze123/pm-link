APP_ENV=stage
SPRING_PROFILES_ACTIVE=stage
IMPORT_DATABASE=false

REMOTE_HOST=192.168.1.107
REMOTE_USER=root
REMOTE_DEPLOY_DIR=/home/daiwei/deployments/ruoyi-release

MYSQL_DATABASE=ruoyi-vue-pro
MYSQL_ROOT_PASSWORD=REPLACE_ME_STAGE_MYSQL_ROOT_PASSWORD
MYSQL_PORT=13306
REDIS_PORT=16379
SERVER_PORT=48080
ADMIN_PORT=5666

JAVA_OPTS="-Xms512m -Xmx1024m -Djava.security.egd=file:/dev/./urandom"
MASTER_DATASOURCE_URL=jdbc:mysql://mysql:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
MASTER_DATASOURCE_USERNAME=root
MASTER_DATASOURCE_PASSWORD=REPLACE_ME_STAGE_MYSQL_ROOT_PASSWORD
SLAVE_DATASOURCE_URL=jdbc:mysql://mysql:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
SLAVE_DATASOURCE_USERNAME=root
SLAVE_DATASOURCE_PASSWORD=REPLACE_ME_STAGE_MYSQL_ROOT_PASSWORD
REDIS_HOST=redis

KOD_SSO_ENABLED=true
KOD_SSO_BASE_URL=http://192.168.1.107:8001/
KOD_SSO_APP_NAME=user:all
KOD_SSO_REDIRECT_URI=http://192.168.1.107:5666/#/auth/kod-sso-login?tenantId=1
KOD_SSO_CALLBACK_BASE_URL=http://192.168.1.107:48080
KOD_SSO_TENANT_ID=1
KOD_SSO_AUTO_CREATE_USER=false

WX_MP_APP_ID=REPLACE_ME_STAGE_WX_MP_APP_ID
WX_MP_SECRET=REPLACE_ME_STAGE_WX_MP_SECRET
WX_MINIAPP_APP_ID=REPLACE_ME_STAGE_WX_MINIAPP_APP_ID
WX_MINIAPP_SECRET=REPLACE_ME_STAGE_WX_MINIAPP_SECRET

FRONTEND_ENV_FILE=script/docker/env/frontend.stage.env
