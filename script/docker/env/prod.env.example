APP_ENV=prod
SPRING_PROFILES_ACTIVE=prod
IMPORT_DATABASE=false

REMOTE_HOST=REPLACE_ME_PROD_HOST
REMOTE_USER=REPLACE_ME_PROD_USER
REMOTE_DEPLOY_DIR=REPLACE_ME_PROD_DEPLOY_DIR

MYSQL_DATABASE=ruoyi-vue-pro
MYSQL_ROOT_PASSWORD=REPLACE_ME_PROD_MYSQL_ROOT_PASSWORD
MYSQL_PORT=13306
REDIS_PORT=16379
SERVER_PORT=48080
ADMIN_PORT=18080

JAVA_OPTS="-Xms1024m -Xmx2048m -Djava.security.egd=file:/dev/./urandom"
MASTER_DATASOURCE_URL=jdbc:mysql://mysql:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
MASTER_DATASOURCE_USERNAME=root
MASTER_DATASOURCE_PASSWORD=REPLACE_ME_PROD_MYSQL_ROOT_PASSWORD
SLAVE_DATASOURCE_URL=jdbc:mysql://mysql:3306/ruoyi-vue-pro?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true&rewriteBatchedStatements=true
SLAVE_DATASOURCE_USERNAME=root
SLAVE_DATASOURCE_PASSWORD=REPLACE_ME_PROD_MYSQL_ROOT_PASSWORD
REDIS_HOST=redis

KOD_SSO_ENABLED=true
KOD_SSO_BASE_URL=http://REPLACE_ME_KOD_HOST:8001/
KOD_SSO_APP_NAME=user:all
KOD_SSO_REDIRECT_URI=https://REPLACE_ME_FRONTEND_HOST/oa/#/auth/kod-sso-login?tenantId=1
KOD_SSO_CALLBACK_BASE_URL=https://REPLACE_ME_FRONTEND_HOST
KOD_SSO_TENANT_ID=1
KOD_SSO_AUTO_CREATE_USER=false

WX_MP_APP_ID=REPLACE_ME_PROD_WX_MP_APP_ID
WX_MP_SECRET=REPLACE_ME_PROD_WX_MP_SECRET
WX_MINIAPP_APP_ID=REPLACE_ME_PROD_WX_MINIAPP_APP_ID
WX_MINIAPP_SECRET=REPLACE_ME_PROD_WX_MINIAPP_SECRET

FRONTEND_ENV_FILE=script/docker/env/frontend.prod.env
